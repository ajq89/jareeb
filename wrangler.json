{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "jareeb",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "jareeb.app",
      "custom_domain": true
    }
  ],
  "r2_buckets": [
    {
      "binding": "jareeb-media",
      "bucket_name": "jareeb-media"
    }
  ]
}
